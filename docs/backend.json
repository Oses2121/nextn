
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID from Firebase Authentication."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "URL of the user's profile picture."
        }
      },
      "required": [
        "uid",
        "email"
      ]
    },
    "OrderItem": {
      "title": "Order Item",
      "description": "Represents a single product within an order.",
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "name": {
          "type": "string"
        },
        "price": {
          "type": "number"
        },
        "quantity": {
          "type": "number"
        },
        "imageId": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "price",
        "quantity"
      ]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer's order.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "total": {
          "type": "number"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/OrderItem"
          }
        },
        "shippingInfo": {
          "type": "object",
          "properties": {
            "email": {
              "type": "string",
              "format": "email"
            },
            "firstName": {
              "type": "string"
            },
            "lastName": {
              "type": "string"
            },
            "address": {
              "type": "string"
            },
            "city": {
              "type": "string"
            },
            "zip": {
              "type": "string"
            }
          }
        }
      },
      "required": [
        "userId",
        "createdAt",
        "total",
        "items",
        "shippingInfo"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores public user profile information. The document ID must match the user's Firebase Auth UID.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user, matching their Auth UID."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": {
            "$ref": "#/backend/entities/Order"
          },
          "description": "Stores the orders placed by a user.",
          "params": [
            {
              "name": "userId",
              "description": "The UID of the user."
            },
            {
              "name": "orderId",
              "description": "The unique identifier for the order."
            }
          ]
        }
      }
    ],
    "reasoning": "The Firestore data structure is designed to be simple and secure. The primary collection is `/users`, where each document's ID is the Firebase Authentication UID of the user. This enforces a strict one-to-one relationship between an authentication identity and a user profile document, enabling strong, path-based security rules. All user-specific data that is not collaborative can be stored in sub-collections under the user's document, ensuring data isolation and straightforward ownership rules."
  }
}


{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID from Firebase Authentication."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "URL of the user's profile picture."
        },
        "wishlist": {
          "type": "array",
          "description": "An array of product IDs the user has wishlisted.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "uid",
        "email"
      ]
    },
    "Category": {
      "title": "Category",
      "description": "Represents a product category.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "slug"
      ]
    },
    "Product": {
      "title": "Product",
      "description": "Represents a product in the store.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "basePrice": {
          "type": "number",
          "description": "The base price for listing pages."
        },
        "category": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "imageId": {
          "type": "string"
        },
        "variants": {
          "type": "array",
          "description": "Product variants like size or color.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "e.g., Small, Medium, Large"
              },
              "price": {
                "type": "number"
              },
              "stock": {
                "type": "number"
              }
            },
            "required": [
              "name",
              "price",
              "stock"
            ]
          }
        }
      },
      "required": [
        "name",
        "basePrice",
        "category",
        "variants"
      ]
    },
    "OrderItem": {
      "title": "Order Item",
      "description": "Represents a single product within an order.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "price": {
          "type": "number"
        },
        "category": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "imageId": {
          "type": "string"
        },
        "quantity": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "name",
        "price",
        "quantity"
      ]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer's order.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "total": {
          "type": "number"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/backend/entities/OrderItem"
          }
        },
        "shippingInfo": {
          "type": "object",
          "properties": {
            "email": {
              "type": "string",
              "format": "email"
            },
            "firstName": {
              "type": "string"
            },
            "lastName": {
              "type": "string"
            },
            "address": {
              "type": "string"
            },
            "city": {
              "type": "string"
            },
            "zip": {
              "type": "string"
            }
          }
        }
      },
      "required": [
        "userId",
        "createdAt",
        "total",
        "items",
        "shippingInfo"
      ]
    },
    "ProductReview": {
      "title": "Product Review",
      "description": "Represents a user's review of a product.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who wrote the review."
        },
        "userName": {
          "type": "string",
          "description": "The display name of the user who wrote the review."
        },
        "productId": {
          "type": "string",
          "description": "The ID of the product being reviewed."
        },
        "rating": {
          "type": "number",
          "description": "The star rating given by the user (1-5)."
        },
        "comment": {
          "type": "string",
          "description": "The text content of the review."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the review was created."
        }
      },
      "required": [
        "userId",
        "userName",
        "productId",
        "rating",
        "comment",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores public user profile information. The document ID must match the user's Firebase Auth UID.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user, matching their Auth UID."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": {
            "$ref": "#/backend/entities/Order"
          },
          "description": "Stores the orders placed by a user.",
          "params": [
            {
              "name": "userId",
              "description": "The UID of the user."
            },
            {
              "name": "orderId",
              "description": "The unique identifier for the order."
            }
          ]
        }
      },
      {
        "path": "/reviews/{reviewId}",
        "definition": {
          "entityName": "ProductReview",
          "schema": {
            "$ref": "#/backend/entities/ProductReview"
          },
          "description": "Stores all product reviews. Can be read by anyone, but only created by authenticated users.",
          "params": [
            {
              "name": "reviewId",
              "description": "The unique identifier for the review."
            }
          ]
        }
      },
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": {
            "$ref": "#/backend/entities/Product"
          },
          "description": "Stores all products available in the shop. Can be read by anyone, but only writable by admins.",
          "params": [
            {
              "name": "productId",
              "description": "The unique identifier for the product."
            }
          ]
        }
      },
      {
        "path": "/categories/{categoryId}",
        "definition": {
          "entityName": "Category",
          "schema": {
            "$ref": "#/backend/entities/Category"
          },
          "description": "Stores all product categories. Can be read by anyone.",
          "params": [
            {
              "name": "categoryId",
              "description": "The unique identifier for the category."
            }
          ]
        }
      }
    ],
    "reasoning": "The Firestore data structure is designed to be simple and secure. User-specific data is nested under `/users/{userId}` to enable path-based ownership rules. Public or collaborative data like products, categories, and reviews are stored in top-level collections with their own specific security rules. This separation allows for both strong user data isolation and flexible public access."
  }
}
